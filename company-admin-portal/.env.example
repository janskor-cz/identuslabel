# Enterprise Database Configuration
# Copy this file to .env and fill in the values

# REQUIRED: Enterprise PostgreSQL database password
# Generate with: openssl rand -hex 32
ENTERPRISE_DB_PASSWORD=your-secure-password-here

# Optional: Override default database connection settings
# ENTERPRISE_DB_HOST=91.99.4.54
# ENTERPRISE_DB_PORT=5434
# ENTERPRISE_DB_NAME=pollux_enterprise
# ENTERPRISE_DB_USER=identus_enterprise

# Iagon Decentralized Storage Configuration
# Generate Access Token: https://app.iagon.com/ -> Settings -> "Generate Token"
# Node ID: Obtained after registering a storage node
# See: https://api.docs.iagon.com/

# REQUIRED for document storage: Iagon API Access Token
IAGON_ACCESS_TOKEN=your-iagon-access-token-here

# REQUIRED for document storage: Your Iagon storage node ID
IAGON_NODE_ID=your-iagon-node-id-here

# Optional: Custom tunneling URL for your storage node (for uploads)
# IAGON_TUNNELING_URL=https://your-node-tunneling-url

# Optional: Override default Iagon download base URL
# IAGON_DOWNLOAD_BASE_URL=https://gw.v2.iagon.com/api/v2

# Document Access Service — URL of the deployed identus-document-service
# When set, DocumentAccessGate service endpoints are embedded in document DIDs
# at creation time so the stateless service can locate them via DID resolution.
# Example: https://identuslabel.cz/document-service
DOCUMENT_SERVICE_URL=

# Optional: Webhook URL for audit events (POSTed on every access grant/deny)
AUDIT_WEBHOOK_URL=

# Classification Master Keys (CMK) — Task 1: Three-Tier Encryption Architecture
# Each must be a base64-encoded 256-bit (32-byte) random value.
# Generate with: node -e "const c=require('crypto'); console.log(c.randomBytes(32).toString('base64'))"
# WARNING: Keep these secret. Rotating them requires re-wrapping all stored DEKs.
CMK_INTERNAL=mTz2nz9Dnk9YmXuPMlDEpdDDn5N9JTWnrjIPa5v9Ywc=
CMK_CONFIDENTIAL=Hfa4R8S4+bEAUNDwX1htW/ZGzKAWMOU7T7DRFYNHQ/0=
CMK_RESTRICTED=QayuGG1LvK/fSljWjwBgseF6SX5+ElCaai94b0BOxmM=
CMK_TOP_SECRET=ru/e3m/6PqTDAInMZUCPmhM5AoGmkRcG+CdLOyIq1TE=
