PORT=3020

# Enterprise Cloud Agent — used for DID resolution
ENTERPRISE_CLOUD_AGENT_URL=https://identuslabel.cz/enterprise
ENTERPRISE_CLOUD_AGENT_API_KEY=

# Iagon decentralized storage credentials
IAGON_ACCESS_TOKEN=
IAGON_NODE_ID=
IAGON_DOWNLOAD_BASE_URL=https://gw.iagon.com/api/v2

# Optional: fallback audit webhook if DID has no AuditLog service endpoint
AUDIT_FALLBACK_URL=

# Slack incoming webhook URL — post ACCESS_GRANTED / ACCESS_DENIED events to Slack
# Generate at: Slack workspace → Apps → Incoming Webhooks → Add New Webhook to Workspace
SLACK_WEBHOOK_URL=

# Company Admin Portal — DIDComm orchestration for two-step document access
COMPANY_ADMIN_URL=http://localhost:3010
COMPANY_ADMIN_KEY=change-me

# DIDComm Identity — service wallet in the multitenancy agent
# Auto-populated on first startup if left empty; saved to data/service-wallet.json
DOC_SERVICE_AGENT_URL=http://91.99.4.54:8200
DOC_SERVICE_WALLET_ID=
DOC_SERVICE_WALLET_API_KEY=

# TrustRegistry — independent issuer verification per VC type
# CA issuer DID for SecurityClearanceGrant VCs
TRUSTED_CA_DID=
# Comma-separated company-admin issuer DIDs for EmployeeRole VCs
TRUSTED_COMPANY_ADMIN_DIDS=

# Admin API key — required for all write operations AND the /admin web UI
# Generate with: openssl rand -hex 32
ADMIN_API_KEY=

# Iagon fileId of the document-index.json blob (enables GET /documents)
# Leave empty to disable listing. Auto-created on first POST /documents.
# Update this value after each service restart to point at the latest index.
DOCUMENT_INDEX_FILE_ID=

# Public base URL of this service (embedded in DID #access service endpoints)
DOCUMENT_SERVICE_URL=https://identuslabel.cz/document-service

# Classification Master Keys (CMK) — Task 1: Three-Tier Encryption Architecture
# Each must be a base64-encoded 256-bit (32-byte) random value.
# Generate with: node -e "const c=require('crypto'); console.log(c.randomBytes(32).toString('base64'))"
# WARNING: Keep these secret. Rotating them requires re-wrapping all stored DEKs.
CMK_INTERNAL=mTz2nz9Dnk9YmXuPMlDEpdDDn5N9JTWnrjIPa5v9Ywc=
CMK_CONFIDENTIAL=Hfa4R8S4+bEAUNDwX1htW/ZGzKAWMOU7T7DRFYNHQ/0=
CMK_RESTRICTED=QayuGG1LvK/fSljWjwBgseF6SX5+ElCaai94b0BOxmM=
CMK_TOP_SECRET=ru/e3m/6PqTDAInMZUCPmhM5AoGmkRcG+CdLOyIq1TE=
